# ElderMind (never commit real keys)
APP_ENV=dev
CORS_ALLOW_ORIGINS=*
BASE_URL=http://127.0.0.1:8010
MEDIA_DIR=backend_media
GATEWAY_PORT=8010
AI_SERVICE_URL=http://127.0.0.1:8001
DATA_SERVICE_URL=http://127.0.0.1:8002
ALERTS_SERVICE_URL=http://127.0.0.1:8003
GATEWAY_URL=http://127.0.0.1:8010
AI_SERVICE_PORT=8001
DATA_SERVICE_PORT=8002
ALERTS_SERVICE_PORT=8003

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Tavily (optional)
TAVILY_API_KEY=

# Gemini (optional fallback)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# MongoDB (required)
DATA_STORE_MODE=mongo
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGO_DB_NAME=eldermind

# Twilio (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=

# Meta WhatsApp Cloud API (optional urgent healthcare alerts)
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_VERSION=v21.0

# OpenWeather (optional)
OPENWEATHER_API_KEY=

# VedAstro (optional calendar context)
VEDASTRO_BASE_URL=https://api.vedastro.org
VEDASTRO_AYANAMSA=RAMAN
DEFAULT_TZ_OFFSET=+05:30
